// -*- mode: jsonc -*-
//
// Adopted from dot/catppuccin Waybar
{
  "layer": "top", // Waybar at top layer
  // "position": "bottom", // Waybar position (top|bottom|left|right)
  // "height": 30, // Waybar height (to be removed for auto height)
  // "width": 1280, // Waybar width
  "spacing": 4, // Gaps between modules (4px)
  "margin-left": 100,
  "margin-right": 100,
  // Choose the order of the modules
  "modules-left": [
    "hyprland/workspaces",
    "custom/active-icon-window",
    "hyprland/window",
    "battery",
    "battery#bat2"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "mpris",
    "custom/weather",
    // "custom/swaync",
    // "sway/language",
    // "backlight",
    //"network",
    // "bluetooth",
    "custom/systeminfo",
    "custom/notification",
    "pulseaudio",
    "tray",
    "custom/scroll-indicator-left",
    "custom/scroll-indicator-right",
    "custom/fullscreen",
    "custom/fullscreen-indicator",
    "custom/move_window_next_monitor",
    "custom/kill_active",
    "custom/power"
  ],
  // Modules configuration
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "default": "¯Äì",
      "focused": "¯Äø",
      "urgent": "¯Äø",
      "visible": " "
    },
    "tooltip": true,
    "tooltip-format": "{name}",
    "persistent-workspaces": {
      "DP-1": [
        1,
        2,
        3,
        4,
        5
      ],
      "HDMI-A-1": [
        6,
        7,
        8,
        9,
        10
      ]
    }
  },
  "hyprland/window": {
    "format": "{title}",
    "max-length": 80
  },
  "custom/active-icon-window": {
    "exec": "~/.dotfiles/hyprland/waybar/scripts/active_icon_window.sh",
    "interval": 1,
    "format": "{}",
    "tooltip": false
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "custom/cava": {
    "format": "¯¥Ø ",
    "tooltip": false,
    "on-click": "kitty -e cava"
  },
  "custom/waypaper": {
    "format": "´Ç¥ ",
    "tooltip": false,
    "on-click": "waypaper"
  },
  "custom/gpt": {
    "format": " ",
    "tooltip": false,
    "on-click": "firefox -P ai --new-window https://chatgpt.com/"
  },
  "sway/scratchpad": {
    "format": "{icon} {count}",
    "show-empty": false,
    "format-icons": [
      "",
      "´ïÆ"
    ],
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },
  "custom/weather": {
    "exec": "~/.dotfiles/hyprland/waybar/scripts/waybar-weather.sh",
    "on-click": "flatpak run io.github.amit9838.mousam",
    "interval": 600,
    "return-type": "json",
    "tooltip": true
  },
  // System load average
  "custom/notification": {
    "format": "´â│",
    "on-click": "makoctl restore",
    "on-click-right": "makoctl restore",
    "tooltip-format": "Notifications"
  },
  "tray": {
    // "icon-size": 21,
    "spacing": 10
  },
  "clock": {
    "format": "{:%Y-%m-%d | %H:%M} ´Çù ",
    "format-alt": "{:%A, %B %d, %Y (%R)} ´ù» ",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "memory": {
    "format": "{}% ´âë"
  },
  "custom/swaync": {
    "exec": "~/.dotfiles/hyprland/waybar/scripts/waybar-swaync.sh",
    "interval": 1,
    "tooltip": false,
    "format": "{} ",
    "on-click": "swaync-client -t"
  },
  "backlight": {
    // "device": "acpi_video1",
    "format": "{percent}% {icon}",
    "format-icons": [
      "¯Äì",
      "¯Åô",
      "¯Åæ",
      "¯ÅÅ",
      "¯ÅÄ",
      "¯Åì",
      "¯Åè",
      "¯Åê",
      "¯Äø"
    ]
  },
  "network": {
    "format-wifi": "{signalStrength}% ´ç½",
    "format-ethernet": "¯╝ë",
    "format-linked": "{ifname} (No IP) ¯╝ë",
    "format-disconnected": "¾░ñ¡",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ´ç½\nIP: {ipaddr}\nGW: {gwaddr}",
    "tooltip-format-ethernet": "{ifname} ¯╝ë\nIP: {ipaddr}\nGW: {gwaddr}",
    "tooltip-format-disconnected": "Disconnected"
  },
  "bluetooth": {
    "format": "{status} ´èö",
    "format-connected": "{num_connections} ´èö",
    "format-disabled": "´û▒",
    "tooltip": true
  },
  "custom/systeminfo": {
    "exec": "~/.dotfiles/hyprland/waybar/scripts/sys_info_json.sh",
    "return-type": "json",
    "interval": 10,
    "on-click": "~/.dotfiles/hyprland/waybar/scripts/sys_info_modal.sh",
    "tooltip": true
  },
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% ´âº",
    "format-plugged": "{capacity}% ´çª",
    "format-alt": "{time} {icon}",
    "interval": 3,
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": [
      "´ëä ",
      "´ëâ ",
      "´ëé ",
      "´ëü ",
      "´ëÇ "
    ]
  },
  "battery#bat2": {
    "bat": "BAT2"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "´âº",
      "performance": "´âº",
      "balanced": "´ëÄ",
      "power-saver": "´ü¼"
    }
  },
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon} ´èö",
    "format-bluetooth-muted": "´æª  {icon} ´èö",
    "format-muted": "´æª ",
    "format-source": " {volume}% ´ä░",
    "format-source-muted": "´ä▒",
    "format-icons": {
      "headphone": "´ÇÑ",
      "hands-free": "´ûÉ",
      "headset": "´ûÉ",
      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": [
        "´Çª",
        "´Çº",
        "´Ç¿ "
      ]
    },
    "on-click": "pavucontrol",
    "on-click-right": "~/.config/rofi/scripts/audio-output-selector.sh",
    "on-scroll-up": "~/.dotfiles/hyprland/hypr/scripts/volnotify.sh +1",
    "on-scroll-down": "~/.dotfiles/hyprland/hypr/scripts/volnotify.sh -1"
  },
  "mpris": {
    "format": "{player_icon} {artist} - {title}",
    "format-paused": "{status_icon} {artist} - {title}",
    "tooltip-format": "{player} ({status})\n{artist} - {title}\n\nLeft-Click:   Play / Pause\nMiddle-Click: Previous Track\nRight-Click:  Next Track",
    "title-len": 25,
    "artist-len": 25,
    "player-icons": {
      "default": "ÔûÂ",
      "mpv": "´Çü",
      "spotify": "¾░ôç"
    },
    "status-icons": {
      "paused": "´üî",
      "stopped": "´æº"
    }
  },
  "custom/power": {
    "format": " ÔÅ╗ ",
    "tooltip": false,
    "on-click": "~/.dotfiles/hyprland/waybar/scripts/wlogout.sh",
    "on-click-right": "~/.dotfiles/rofi/scripts/launchers/type-7/launcher.sh"
  },
  "custom/fullscreen": {
    "exec": "~/.dotfiles/hyprland/waybar/scripts/fullscreen_status.sh",
    "interval": 1,
    "format": "{}",
    "signal": 10,
    "tooltip-format": "Toggle fullscreen",
    "on-click": "hyprctl dispatch fullscreen 1"
  },
  "custom/fullscreen-indicator": {
    "exec": "~/.dotfiles/hyprland/waybar/scripts/fullscreen_indicator.sh",
    "interval": 1,
    "format": "{}",
    "signal": 10,
    "tooltip-format": "Fullscreen mode active",
    "on-click": "hyprctl dispatch fullscreen 1"
  },
  "custom/scroll-indicator-left": {
    "exec": "~/.dotfiles/hyprland/waybar/scripts/scroll_indicator.sh left",
    "interval": 1,
    "format": "{}",
    "signal": 8,
    "tooltip-format": "More windows to the left",
    "on-click": "hyprctl dispatch layoutmsg focus l"
  },
  "custom/scroll-indicator-right": {
    "exec": "~/.dotfiles/hyprland/waybar/scripts/scroll_indicator.sh right",
    "interval": 1,
    "format": "{}",
    "signal": 9,
    "tooltip-format": "More windows to the right",
    "on-click": "hyprctl dispatch layoutmsg focus r"
  },
  "custom/move_window_next_monitor": {
    "format": "¯»ï",
    "tooltip-format": "Move window to next monitor (cycles through all monitors)",
    "on-click": "~/.dotfiles/hyprland/waybar/scripts/move_window_next_monitor.sh",
    "on-click-right": "~/.dotfiles/hyprland/waybar/scripts/send-window-to-workspace.sh"
  },
  "custom/kill_active": {
    "format": "¾░àÖ",
    "tooltip-format": "Kill active window",
    "on-click": "hyprctl dispatch killactive"
  }
}