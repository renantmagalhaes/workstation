// -*- mode: jsonc -*-
//
// Adopted from dot/catppuccin Waybar
{
  "layer": "top", // Waybar at top layer
  "spacing": 4, // Gaps between modules (4px)
  "margin-left": 100,
  "margin-right": 100,
  // Choose the order of the modules
  "modules-left": [
    "mango/workspaces",
    "group/window-capsule",
    "battery",
    "battery#bat2"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "mpris",
    "custom/weather",
    "custom/systeminfo",
    "custom/notification",
    "pulseaudio",
    "tray",
    "custom/scroll-indicator-left",
    "custom/scroll-indicator-right",
    "custom/fullscreen",
    "custom/fullscreen-indicator",
    "custom/move_window_next_monitor",
    "custom/kill_active",
    "custom/power"
  ],
  "group/window-capsule": {
    "orientation": "horizontal",
    "name": "window-capsule",
    "modules": [
      "custom/active-icon-window",
      "mango/window"
    ]
  },
  // Modules configuration
  "mango/workspaces": {
    "on-click": "activate"
  },
  "mango/window": {
    "format": "{title}",
    "max-length": 80
  },
  "custom/active-icon-window": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/active_icon_window.sh",
    "interval": 1,
    "format": "{}",
    "tooltip": false
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "custom/cava": {
    "format": "оЊЭ ",
    "tooltip": false,
    "on-click": "kitty -e cava"
  },
  "custom/waypaper": {
    "format": "пАЊ ",
    "tooltip": false,
    "on-click": "waypaper"
  },
  "custom/gpt": {
    "format": " ",
    "tooltip": false,
    "on-click": "firefox -P ai --new-window https://chatgpt.com/"
  },
  "sway/scratchpad": {
    "format": "{icon} {count}",
    "show-empty": false,
    "format-icons": [
      "",
      "пЛТ"
    ],
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },
  "custom/weather": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/waybar-weather.sh",
    "on-click": "flatpak run io.github.amit9838.mousam",
    "interval": 600,
    "return-type": "json",
    "tooltip": true
  },
  "custom/notification": {
    "format": "пГ≥",
    "on-click": "makoctl restore",
    "on-click-right": "makoctl restore",
    "tooltip-format": "Notifications"
  },
  "tray": {
    "spacing": 10
  },
  "clock": {
    "format": "{:%Y-%m-%d | %H:%M} пАЧ ",
    "format-alt": "{:%A, %B %d, %Y (%R)} пЧѓ ",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "memory": {
    "format": "{}% пГЙ"
  },
  "custom/swaync": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/waybar-swaync.sh",
    "interval": 1,
    "tooltip": false,
    "format": "{} ",
    "on-click": "swaync-client -t"
  },
  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": [
      "оОН",
      "оПУ",
      "оПС",
      "оПП",
      "оПО",
      "оПН",
      "оПК",
      "оПИ",
      "оОЫ"
    ]
  },
  "network": {
    "format-wifi": "{signalStrength}% пЗЂ",
    "format-ethernet": "оЉЙ",
    "format-linked": "{ifname} (No IP) оЉЙ",
    "format-disconnected": "у∞§≠",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) пЗЂ\nIP: {ipaddr}\nGW: {gwaddr}",
    "tooltip-format-ethernet": "{ifname} оЉЙ\nIP: {ipaddr}\nGW: {gwaddr}",
    "tooltip-format-disconnected": "Disconnected"
  },
  "bluetooth": {
    "format": "{status} пКФ",
    "format-connected": "{num_connections} пКФ",
    "format-disabled": "пЦ±",
    "tooltip": true
  },
  "custom/systeminfo": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/sys_info_json.sh",
    "return-type": "json",
    "interval": 10,
    "on-click": "~/.dotfiles/mangowm/waybar/scripts/sys_info_modal.sh",
    "tooltip": true
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% пГІ",
    "format-plugged": "{capacity}% пЗ¶",
    "format-alt": "{time} {icon}",
    "interval": 3,
    "format-icons": [
      "пЙД ",
      "пЙГ ",
      "пЙВ ",
      "пЙБ ",
      "пЙА "
    ]
  },
  "battery#bat2": {
    "bat": "BAT2"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "пГІ",
      "performance": "пГІ",
      "balanced": "пЙО",
      "power-saver": "пБђ"
    }
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon} пКФ",
    "format-bluetooth-muted": "пС¶  {icon} пКФ",
    "format-muted": "пС¶ ",
    "format-source": " {volume}% пД∞",
    "format-source-muted": "пД±",
    "format-icons": {
      "headphone": "пА•",
      "hands-free": "пЦР",
      "headset": "пЦР",
      "phone": "пВХ",
      "portable": "пВХ",
      "car": "пЖє",
      "default": [
        "пА¶",
        "пАІ",
        "пА® "
      ]
    },
    "on-click": "pavucontrol",
    "on-click-right": "~/.config/rofi/scripts/audio-output-selector.sh",
    "on-scroll-up": "~/.dotfiles/mangowm/scripts/volnotify.sh +1",
    "on-scroll-down": "~/.dotfiles/mangowm/scripts/volnotify.sh -1"
  },
  "mpris": {
    "format": "{player_icon} {artist} - {title}",
    "format-paused": "{status_icon} {artist} - {title}",
    "tooltip-format": "{player} ({status})\n{artist} - {title}\n\nLeft-Click:   Play / Pause\nMiddle-Click: Previous Track\nRight-Click:  Next Track",
    "title-len": 25,
    "artist-len": 25,
    "player-icons": {
      "default": "вЦґ",
      "mpv": "пАБ",
      "spotify": "у∞УЗ"
    },
    "status-icons": {
      "paused": "пБМ",
      "stopped": "пСІ"
    }
  },
  "custom/power": {
    "format": " вПї ",
    "tooltip": false,
    "on-click": "~/.dotfiles/mangowm/waybar/scripts/wlogout.sh",
    "on-click-right": "~/.dotfiles/rofi/scripts/launchers/type-7/launcher.sh"
  },
  "custom/fullscreen": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/fullscreen_status.sh",
    "interval": 1,
    "format": "{}",
    "signal": 10,
    "tooltip-format": "Toggle fullscreen",
    "on-click": "env MANGO_INSTANCE_SIGNATURE=/run/user/1000/mango-$(pgrep -x mango).sock mmsg dispatch switch_proportion_preset"
  },
  "custom/fullscreen-indicator": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/fullscreen_indicator.sh",
    "interval": 1,
    "format": "{}",
    "signal": 10,
    "tooltip-format": "Fullscreen mode active",
    "on-click": "env MANGO_INSTANCE_SIGNATURE=/run/user/1000/mango-$(pgrep -x mango).sock mmsg dispatch switch_proportion_preset"
  },
  "custom/move_window_next_monitor": {
    "format": "оѓЛ",
    "tooltip-format": "Move window to next monitor (cycles through all monitors)",
    "on-click": "~/.dotfiles/mangowm/waybar/scripts/move_window_next_monitor.sh",
    "on-click-right": "~/.dotfiles/mangowm/waybar/scripts/send-window-to-workspace.sh"
  },
  "custom/kill_active": {
    "format": "у∞ЕЩ",
    "tooltip-format": "Kill active window",
    "on-click": "env MANGO_INSTANCE_SIGNATURE=/run/user/1000/mango-$(pgrep -x mango).sock mmsg dispatch killclient"
  },
  "custom/scroll-indicator-left": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/scroll_indicator.sh left",
    "interval": 1,
    "format": "{}",
    "signal": 8,
    "tooltip-format": "More windows to the left",
    "on-click": "~/.dotfiles/mangowm/waybar/scripts/scroll_indicator.sh click_left"
  },
  "custom/scroll-indicator-right": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/scroll_indicator.sh right",
    "interval": 1,
    "format": "{}",
    "signal": 8,
    "tooltip-format": "More windows to the right",
    "on-click": "~/.dotfiles/mangowm/waybar/scripts/scroll_indicator.sh click_right"
  }
}