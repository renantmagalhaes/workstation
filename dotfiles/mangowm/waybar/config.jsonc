// -*- mode: jsonc -*-
//
// Adopted from dot/catppuccin Waybar
{
  "layer": "top", // Waybar at top layer
  "spacing": 4, // Gaps between modules (4px)
  "margin-left": 100,
  "margin-right": 100,
  // Choose the order of the modules
  "modules-left": [
    "dwl/tags",
    "custom/active-icon-window",
    "dwl/window",
    "battery",
    "battery#bat2"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "mpris",
    "custom/weather",
    "custom/systeminfo",
    "custom/notification",
    "pulseaudio",
    "tray",
    "custom/scroll-indicator-left",
    "custom/scroll-indicator-right",
    "custom/fullscreen",
    "custom/fullscreen-indicator",
    "custom/move_window_next_monitor",
    "custom/kill_active",
    "custom/power"
  ],
  // Modules configuration
  "dwl/tags": {
    "num-tags": 9
  },
  "dwl/window": {
    "format": "{title}",
    "max-length": 80
  },
  "custom/active-icon-window": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/active_icon_window.sh",
    "interval": 1,
    "format": "{}",
    "tooltip": false
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "custom/cava": {
    "format": "оѕќ ",
    "tooltip": false,
    "on-click": "kitty -e cava"
  },
  "custom/waypaper": {
    "format": "пЂѕ ",
    "tooltip": false,
    "on-click": "waypaper"
  },
  "custom/gpt": {
    "format": " ",
    "tooltip": false,
    "on-click": "firefox -P ai --new-window https://chatgpt.com/"
  },
  "sway/scratchpad": {
    "format": "{icon} {count}",
    "show-empty": false,
    "format-icons": [
      "",
      "п‹’"
    ],
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },
  "custom/weather": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/waybar-weather.sh",
    "on-click": "flatpak run io.github.amit9838.mousam",
    "interval": 600,
    "return-type": "json",
    "tooltip": true
  },
  "custom/notification": {
    "format": "пѓі",
    "on-click": "makoctl restore",
    "on-click-right": "makoctl restore",
    "tooltip-format": "Notifications"
  },
  "tray": {
    "spacing": 10
  },
  "clock": {
    "format": "{:%Y-%m-%d | %H:%M} пЂ— ",
    "format-alt": "{:%A, %B %d, %Y (%R)} п—Ї ",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "memory": {
    "format": "{}% пѓ‰"
  },
  "custom/swaync": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/waybar-swaync.sh",
    "interval": 1,
    "tooltip": false,
    "format": "{} ",
    "on-click": "swaync-client -t"
  },
  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": [
      "оЋЌ",
      "оЏ“",
      "оЏ‘",
      "оЏЏ",
      "оЏЋ",
      "оЏЌ",
      "оЏЉ",
      "оЏ€",
      "оЋ›"
    ]
  },
  "network": {
    "format-wifi": "{signalStrength}% п‡«",
    "format-ethernet": "ој‰",
    "format-linked": "{ifname} (No IP) ој‰",
    "format-disconnected": "у°¤­",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) п‡«\nIP: {ipaddr}\nGW: {gwaddr}",
    "tooltip-format-ethernet": "{ifname} ој‰\nIP: {ipaddr}\nGW: {gwaddr}",
    "tooltip-format-disconnected": "Disconnected"
  },
  "bluetooth": {
    "format": "{status} пЉ”",
    "format-connected": "{num_connections} пЉ”",
    "format-disabled": "п–±",
    "tooltip": true
  },
  "custom/systeminfo": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/sys_info_json.sh",
    "return-type": "json",
    "interval": 10,
    "on-click": "~/.dotfiles/mangowm/waybar/scripts/sys_info_modal.sh",
    "tooltip": true
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% пѓ§",
    "format-plugged": "{capacity}% п‡¦",
    "format-alt": "{time} {icon}",
    "interval": 3,
    "format-icons": [
      "п‰„ ",
      "п‰ѓ ",
      "п‰‚ ",
      "п‰Ѓ ",
      "п‰Ђ "
    ]
  },
  "battery#bat2": {
    "bat": "BAT2"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "пѓ§",
      "performance": "пѓ§",
      "balanced": "п‰Ћ",
      "power-saver": "пЃ¬"
    }
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon} пЉ”",
    "format-bluetooth-muted": "п‘¦  {icon} пЉ”",
    "format-muted": "п‘¦ ",
    "format-source": " {volume}% п„°",
    "format-source-muted": "п„±",
    "format-icons": {
      "headphone": "пЂҐ",
      "hands-free": "п–ђ",
      "headset": "п–ђ",
      "phone": "п‚•",
      "portable": "п‚•",
      "car": "п†№",
      "default": [
        "пЂ¦",
        "пЂ§",
        "пЂЁ "
      ]
    },
    "on-click": "pavucontrol",
    "on-click-right": "~/.config/rofi/scripts/audio-output-selector.sh",
    "on-scroll-up": "~/.dotfiles/mangowm/scripts/volnotify.sh +1",
    "on-scroll-down": "~/.dotfiles/mangowm/scripts/volnotify.sh -1"
  },
  "mpris": {
    "format": "{player_icon} {artist} - {title}",
    "format-paused": "{status_icon} {artist} - {title}",
    "tooltip-format": "{player} ({status})\n{artist} - {title}\n\nLeft-Click:   Play / Pause\nMiddle-Click: Previous Track\nRight-Click:  Next Track",
    "title-len": 25,
    "artist-len": 25,
    "player-icons": {
      "default": "в–¶",
      "mpv": "пЂЃ",
      "spotify": "у°“‡"
    },
    "status-icons": {
      "paused": "пЃЊ",
      "stopped": "п‘§"
    }
  },
  "custom/power": {
    "format": " вЏ» ",
    "tooltip": false,
    "on-click": "~/.dotfiles/mangowm/waybar/scripts/wlogout.sh",
    "on-click-right": "~/.dotfiles/rofi/scripts/launchers/type-7/launcher.sh"
  },
  "custom/fullscreen": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/fullscreen_status.sh",
    "interval": 1,
    "format": "{}",
    "signal": 10,
    "tooltip-format": "Toggle fullscreen",
    "on-click": "mmsg -d switch_proportion_preset"
  },
  "custom/fullscreen-indicator": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/fullscreen_indicator.sh",
    "interval": 1,
    "format": "{}",
    "signal": 10,
    "tooltip-format": "Fullscreen mode active",
    "on-click": "mmsg -d switch_proportion_preset"
  },
  "custom/move_window_next_monitor": {
    "format": "оЇ‹",
    "tooltip-format": "Move window to next monitor (cycles through all monitors)",
    "on-click": "~/.dotfiles/mangowm/waybar/scripts/move_window_next_monitor.sh",
    "on-click-right": "~/.dotfiles/mangowm/waybar/scripts/send-window-to-workspace.sh"
  },
  "custom/kill_active": {
    "format": "у°…™",
    "tooltip-format": "Kill active window",
    "on-click": "mmsg -d killclient"
  },
  "custom/scroll-indicator-left": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/scroll_indicator.sh left",
    "interval": 1,
    "format": "{}",
    "signal": 8,
    "tooltip-format": "More windows to the left",
    "on-click": "~/.dotfiles/mangowm/waybar/scripts/scroll_indicator.sh click_left"
  },
  "custom/scroll-indicator-right": {
    "exec": "~/.dotfiles/mangowm/waybar/scripts/scroll_indicator.sh right",
    "interval": 1,
    "format": "{}",
    "signal": 8,
    "tooltip-format": "More windows to the right",
    "on-click": "~/.dotfiles/mangowm/waybar/scripts/scroll_indicator.sh click_right"
  }
}